<h1>ログイン</h1>

<% if flash[:alert] %>
  <ul style="color: red;">
    <% flash[:alert].to_s.split('<br>').each do |msg| %>
      <li><%= msg.html_safe %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with(url: session_path, local: true) do |form| %>
  <div>
    <%= form.label :user_id, "ユーザーID" %>
    <%= form.text_field :user_id %>
  </div>
  <div>
    <%= form.label :password, "パスワード" %>
    <%= form.password_field :password %>
  </div>
  <div>
    <%= form.submit "ログイン" %>
  </div>
<% end %>